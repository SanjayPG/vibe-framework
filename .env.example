# Vibe Framework - AI Provider API Keys
# Choose one or more providers:

# OpenAI (GPT-4, GPT-4o, GPT-4o-mini)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (Free tier available)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude (3.5 Sonnet, Opus, Haiku)
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DeepSeek (Affordable pricing)
# Get key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Groq (Extremely fast, free tier)
# Get key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Local/Custom Model Endpoint (Optional)
# For localhost: http://localhost:8000
# For Cloudflare tunnel: https://xyz.trycloudflare.com
# For ngrok: https://xyz.ngrok.io
# For Colab: https://xyz.trycloudflare.com
LOCAL_MODEL_URL=https://your-endpoint-url-here

# Local Model Name (the model available on your endpoint)
# Examples: deepseek-coder-v2:16b, llama-3.3-70b-versatile, gpt-4, custom-model, etc.
LOCAL_MODEL_NAME=your-model-name-here

# Local Model API Path (OpenAI compatible endpoint path)
# Common options: /v1/chat/completions, /chat, /api/chat
LOCAL_MODEL_API_PATH=/v1/chat/completions
